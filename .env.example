# VidTone Agent runtime mode
# true = no paid API required, useful for local demo and UI testing
# false = call Fireworks AI API
USE_MOCK=false

# Fireworks AI
FIREWORKS_API_KEY=
# gpt-oss-120b is the model we verified end-to-end for both caption and
# strict-JSON judge passes. If your Fireworks account has access to Gemma
# (e.g. accounts/fireworks/models/gemma-3-27b-it) swap it in here to also
# qualify for the Best Use of Gemma in Video Captioning partner prize.
FIREWORKS_MODEL=accounts/fireworks/models/gpt-oss-120b
# Used by /api/models to discover Fireworks model choices for the UI.
# `fireworks` lists the public Fireworks model library. Change this to your
# account id if you want to include custom/private models.
FIREWORKS_ACCOUNT_ID=fireworks
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1/chat/completions

# Optional vision model on Fireworks (leave empty to skip visual analysis).
# When set, top keyframes are sent to this model and its description is
# merged into the video_context that CaptionAgent and JudgeAgent see.
# Recommended examples (check availability on your account):
#   accounts/fireworks/models/qwen2p5-vl-32b-instruct
#   accounts/fireworks/models/llama-v3p2-11b-vision-instruct
FIREWORKS_VISION_MODEL=

# Pipeline
MAX_RETRIES=2
MIN_VIDEO_SECONDS=30
MAX_VIDEO_SECONDS=120
OUTPUT_DIR=outputs
UPLOAD_DIR=uploads
KEYFRAME_INTERVAL_SECONDS=10
MAX_KEYFRAMES=8
MAX_VISION_FRAMES=3
